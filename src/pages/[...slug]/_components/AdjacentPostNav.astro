---
import IconArrowLeft from "@/assets/icons/IconArrowLeft.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { getPostUrl } from "@/utils/getPostPaths";
import { useTranslations } from "@/i18n";
import config from "@/config";

type AdjacentPost = {
  id: string;
  title: string;
  filePath: string | undefined;
} | null;

type Props = {
  prevPost: AdjacentPost;
  nextPost: AdjacentPost;
};

const { prevPost, nextPost } = Astro.props;
const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);
---

<div data-pagefind-ignore class="my-8 grid grid-cols-1 gap-6 sm:grid-cols-2">
  {
    prevPost && (
      <a
        href={getPostUrl(prevPost.id, prevPost.filePath, locale)}
        title={prevPost.title}
        class="flex w-full gap-2 hover:opacity-75 items-start"
      >
        <IconArrowLeft class="inline-block flex-none rtl:rotate-180 mt-1" />
        <div>
          <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider block mb-1">
            {t.post.previousPost}
          </span>
          <div class="text-accent/90 text-xs sm:text-sm font-semibold line-clamp-2 leading-relaxed">
            {prevPost.title}
          </div>
        </div>
      </a>
    )
  }
  {
    nextPost && (
      <a
        href={getPostUrl(nextPost.id, nextPost.filePath, locale)}
        title={nextPost.title}
        class="flex w-full justify-end gap-2 text-end hover:opacity-75 sm:col-start-2 items-start"
      >
        <div>
          <span class="text-[10px] font-bold text-muted-foreground uppercase tracking-wider block mb-1">
            {t.post.nextPost}
          </span>
          <div class="text-accent/90 text-xs sm:text-sm font-semibold line-clamp-2 leading-relaxed">
            {nextPost.title}
          </div>
        </div>
        <IconArrowRight class="inline-block flex-none rtl:rotate-180 mt-1" />
      </a>
    )
  }
</div>
